{
  "name": "kicad-to-circuit-json",
  "main": "dist/index.js",
  "type": "module",
  "version": "0.0.77",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:lib",
    "build:lib": "tsup-node lib/index.ts --format esm --dts",
    "build:site": "vite build --config vite.config.ts",
    "dev": "vite --config vite.config.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "download-demos": "git clone --depth 1 --filter=blob:none --sparse https://gitlab.com/kicad/code/kicad.git kicad-demos && cd kicad-demos && git sparse-checkout set demos",
    "preview": "vite preview --config vite.config.ts",
    "pull:reference:notests": "git clone --depth 1 https://github.com/tscircuit/circuit-json-to-kicad circuit-json-to-kicad && rm -rf circuit-json-to-kicad/tests",
    "pull:reference": "git clone --depth 1 https://github.com/tscircuit/circuit-json-to-kicad circuit-json-to-kicad",
    "start": "bun run dev",
    "vercel-build": "bun run build:site"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@tscircuit/circuit-json-util": "^0.0.94",
    "@tscircuit/copper-pour-solver": "^0.0.20",
    "@tscircuit/core": "^0.0.1156",
    "@tscircuit/math-utils": "^0.0.33",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-match-svg": "^0.0.14",
    "circuit-json-to-connectivity-map": "^0.0.23",
    "kicadts": "^0.0.42",
    "react": "^19.2.0",
    "react-dom": "^19.2.5",
    "tscircuit": "^0.0.1775",
    "tsup": "^8.5.0",
    "vercel": "^50.42.0",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "schematic-symbols": "^0.0.202"
  }
}
